{
  "name": "@aim-predict/snap",
  "version": "0.1.1",
  "description": "Prediction Market Aggregator",
  "homepage": "https://www.aimpredict.com/",
  "license": "(MIT-0 OR Apache-2.0)",
  "repository": {
    "type": "git",
    "url": "git+https://git.fluxdesk.net/fps/AIM-Build.git",
    "directory": "packages/snap/packages/snap"
  },
  "main": "./dist/bundle.js",
  "files": [
    "dist/",
    "images/",
    "snap.manifest.json"
  ],
  "scripts": {
    "allow-scripts": "bun run --filter \"snap-root\" allow-scripts",
    "build": "mm-snap build",
    "build:clean": "bun run clean && bun run build",
    "clean": "rimraf dist",
    "lint": "bun run lint:eslint && bun run lint:misc --check",
    "lint:eslint": "eslint . --cache",
    "lint:fix": "bun run lint:eslint --fix && bun run lint:misc --write",
    "lint:misc": "prettier '**/*.json' '**/*.md' '**/*.yml' --ignore-path ../../.gitignore --no-error-on-unmatched-pattern",
    "prepublishOnly": "mm-snap manifest",
    "serve": "mm-snap serve",
    "start": "mm-snap watch",
    "test": "jest"
  },
  "dependencies": {
    "@metamask/snaps-sdk": "~10.3.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.5.0",
    "@metamask/snaps-cli": "^8.3.0",
    "@metamask/snaps-jest": "^9.8.0",
    "eslint": "^9.11.0",
    "jest": "^29.5.0",
    "rimraf": "^3.0.2",
    "ts-jest": "^29.1.0",
    "typescript": "~5.7.3"
  },
  "engines": {
    "node": ">=18.6.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
