{
  "name": "snap-root",
  "version": "0.1.1",
  "private": true,
  "description": "",
  "homepage": "https://www.aimpredict.com/",
  "bugs": {
    "url": "https://git.fluxdesk.net/fps/AIM-Build/-/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://git.fluxdesk.net/fps/AIM-Build.git",
    "directory": "packages/snap"
  },
  "license": "(MIT-0 OR Apache-2.0)",
  "author": "",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter \"@aim-predict/snap\" build",
    "lint": "bun run lint:eslint && bun run lint:misc --check",
    "lint:eslint": "eslint . --cache",
    "lint:fix": "bun run lint:eslint --fix && bun run lint:misc --write",
    "lint:misc": "prettier '**/*.json' '**/*.md' '**/*.yml' --ignore-path .gitignore --no-error-on-unmatched-pattern",
    "start": "bun run --filter \"@aim-predict/snap\" start",
    "test": "bun run --filter \"snap\" test"
  },
  "resolutions": {
    "cookie": "^0.7.1",
    "path-to-regexp@0.1.10": "^0.1.12",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@lavamoat/allow-scripts": "^3.3.4",
    "@lavamoat/preinstall-always-fail": "^2.0.0",
    "@metamask/eslint-config": "^14.0.0",
    "@metamask/eslint-config-jest": "^14.0.0",
    "@metamask/eslint-config-nodejs": "^14.0.0",
    "@metamask/eslint-config-typescript": "^14.0.0",
    "eslint": "^9.11.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import-x": "^4.3.0",
    "eslint-plugin-jest": "^28.8.3",
    "eslint-plugin-jsdoc": "^50.2.4",
    "eslint-plugin-n": "^17.10.3",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-promise": "^7.1.0",
    "prettier": "^3.3.3",
    "prettier-plugin-packagejson": "^2.2.18",
    "sharp": "^0.32.6",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.6.0"
  }
}